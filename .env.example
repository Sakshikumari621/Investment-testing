# Environment Variables
NODE_ENV=production
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://127.0.0.1:27017/investments

# JWT Authentication
JWT_SECRET=replace_me_with_a_secure_jwt_secret_in_production
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Admin Portal Defaults
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
