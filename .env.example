# ─────────────────────────────────────────
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Server
NODE_ENV=production
PORT=5000

# MongoDB — use your Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT Authentication
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# KYC encryption secret (32-byte hex string)
KYC_SECRET=replace_me_with_a_64char_hex_string

# File uploads directory (relative path)
UPLOAD_PATH=uploads

# Payment details shown to users on deposit page
# Payment Details (Frontend)
VITE_NETWORK_1_NAME=TRC20
VITE_NETWORK_1_ADDRESS=your_trc20_address_here
VITE_NETWORK_2_NAME=ERC20
VITE_NETWORK_2_ADDRESS=your_erc20_address_here
VITE_NETWORK_3_NAME=BEP20
VITE_NETWORK_3_ADDRESS=your_bep20_address_here
VITE_UPI_ID=your_upi_id_here

# Admin and Support
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
VITE_SUPPORT_EMAIL=support@goldbaba.com
